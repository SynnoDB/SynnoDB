OPENAI_API_KEY = "YOUR_KEY"
WANDB_ENTITY = "learneddb"
WANDB_PROJECT = "bespoke-olap-agents"

# OpenRouter (via LiteLLM). Needed for --model openrouter/... models.
OPENROUTER_API_KEY = "sk-or-..."

# Lokales llm
LLM_API_BASE = "http://localhost:13505/v1"
# --model openai/unsloth/MiniMax-M2.5

# Zulip Bot Config
ZULIP_ADDR = "add your Zulip address here"
ZULIP_EMAIL = "email of your Zulip bot here"
ZULIP_API_KEY = "API key of your Zulip bot here"

TO_USER = "email of the user to send notifications to here"
TO_CHNL = "name of the Zulip channel to send notifications to here"
TO_TOPIC = "name of the topic in the Zulip channel to send notifications to here"

GIT_SNAPSHOTTER_SERVER = "git://url.git"

SYNNO_DATA_DIR = "/path/to/synno_data_dir"  # e.g., "/mnt/labstore/synno_data_dir"

# The single shared git-snapshotter repository (one bare repo shared by all
# workspaces; a cache artifact that outlives the workspaces). Defaults to
# "<SYNNO_DATA_DIR>/git_snapshotter"; uncomment to relocate it (e.g. to a faster
# local disk). Must be an absolute path.
# SYNNO_SNAPSHOTTER_DIR = "/path/to/snapshotter_dir"

# Set to "1" to have the supervision agent additionally generate developer-facing
# hints (e.g. signs the supervised agent got confused, or a suspected bug/ambiguity
# in the pipeline or prompts) alongside its user-facing run summary. Off by default
# to save tokens.
# GENERATE_DEV_HINTS = "1"
